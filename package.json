{
  "name": "notes1",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "starty": "cross-env DEBUG=notes:* node ./app.mjs",
    "start": "cross-env DEBUG=notes:*,socket.io:* SEQUELIZE_CONNECT=models/sequelize-sqlite.yaml NOTES_MODEL=sequelize HOST=127.0.0.1 PORT=5858 USER_SERVICE_URL=http://127.0.0.1:5858 node ./app.mjs",
    "fs-start": "cross-env DEBUG=notes:* PORT=3000 NOTES_MODEL=fs node ./app.mjs",
    "fs-server1": "cross-env NOTES_MODEL=fs PORT=3001 node ./app.mjs",
    "fs-server2": "cross-env NOTES_MODEL=fs PORT=3002 node ./app.mjs",
    "level-start": "cross-env DEBUG=notes:* PORT=3000 NOTES_MODEL=level node ./app.mjs",
    "sqlite3-setup": "sqlite3 notes.sqlite3 --init models/schema-sqlite3.sql",
    "sqlite3-start": "cross-env  SQLITE_FILE=notes.sqlite3 DEBUG=notes:* NOTES_MODEL=sqlite3 node ./app.mjs",
    "sqlite3-server1": "cross-env SQLITE_FILE=notes.sqlite3 NOTES_MODEL=sqlite3 PORT=3001 node ./app.mjs",
    "sqlite3-server2": "cross-env SQLITE_FILE=notes.sqlite3 NOTES_MODEL=sqlite3 PORT=3002 node ./app.mjs",
    "sequelize-start": "cross-env DEBUG=notes:* SEQUELIZE_CONNECT=models/sequelize-mysql.yaml NOTES_MODEL=sequelize node ./app.mjs",
    "sequelize-server1": "cross-env SEQUELIZE_CONNECT=models/sequelize-mysql.yaml NOTES_MODEL=sequelize PORT=3001 node ./app.mjs",
    "sequelize-server2": "cross-env SEQUELIZE_CONNECT=models/sequelize-mysql.yaml NOTES_MODEL=sequelize PORT=3002 node ./app.mjs",
    "mongodb-start": "cross-env DEBUG=notes:* MONGO_URL=mongodb://127.0.0.1/ MONGO_DBNAME=notes NOTES_MODEL=mongodb node ./app.mjs",
    "mongodb-server1": "cross-env DEBUG=notes:* MONGO_URL=mongodb://127.0.0.1/ MONGO_DBNAME=notes NOTES_MODEL=mongodb PORT=3001 node ./app.mjs",
    "mongodb-server2": "cross-env DEBUG=notes:* MONGO_URL=mongodb://localhost/ MONGO_DBNAME=notes NOTES_MODEL=mongodb PORT=3002 node ./app.mjs"
  },
  "dependencies": {
    "bcrypt": "^5.x",
    "bootstrap": "^4.5.x",
    "cookie-parser": "^1.4.4",
    "cross-env": "^7.x",
    "debug": "^4.1.1",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-session": "^1.17.0",
    "feather-icons": "^4.25.0",
    "fs-extra": "^8.1.0",
    "hbs": "^4.1.x",
    "http-errors": "^1.7.3",
    "jquery": "^3.5.x",
    "js-yaml": "^3.13.1",
    "level": "^6.0.0",
    "memorystore": "^1.6.2",
    "mongodb": "^3.5.2",
    "morgan": "^1.9.1",
    "mysql2": "^3.5.2",
    "passport": "^0.5.3",
    "passport-local": "^1.0.0",
    "passport-twitter": "^1.0.4",
    "passport.socketio": "^3.7.0",
    "popper.js": "^1.16.0",
    "rotating-file-stream": "^2.0.1",
    "sequelize": "^6.2.0",
    "session-file-store": "^1.3.1",
    "socket.io": "^2.3.0",
    "sqlite3": "^5.x",
    "superagent": "^5.2.1"
  },
  "devDependencies": {
    "capture-console": "^1.0.1"
  }
}
